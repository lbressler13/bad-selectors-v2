        <action
            android:id="@+id/navigateCalcToOtp"
            app:destination="@id/otpFragment" />
    </fragment>

    <fragment
        android:id="@+id/dateFragment"
        android:name="xyz.lbres.badselectorsv2.date.DateTabFragment"
        android:label="DateTabFragment">

        <action
            android:id="@+id/navigateDateToHome"
            app:destination="@id/homeFragment" />

        <action
            android:id="@+id/navigateDateToPhone"
            app:destination="@id/phoneFragment" />

        <action
            android:id="@+id/navigateDateToCalc"
            app:destination="@id/calcFragment" />

        <action
            android:id="@+id/navigateDateToOtp"
            app:destination="@id/otpFragment" />
    </fragment>

    <fragment
        android:id="@+id/otpFragment"
        android:name="xyz.lbres.badselectorsv2.otp.OTPTabFragment"
        android:label="OTPTabFragment">

        <action
            android:id="@+id/navigateOtpToHome"
            app:destination="@id/homeFragment" />

        <action
            android:id="@+id/navigateOtpToPhone"
            app:destination="@id/phoneFragment" />

        <action
            android:id="@+id/navigateOtpToCalc"
            app:destination="@id/calcFragment" />

        <action
            android:id="@+id/navigateOtpToDate"
            app:destination="@id/dateFragment" />
    </fragment>

