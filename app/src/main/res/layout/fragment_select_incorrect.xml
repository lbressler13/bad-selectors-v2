<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="@dimen/tab_activity_top_padding">

    <include
        android:id="@+id/digitsLayout"
        layout="@layout/component_phone_number" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainBody"
        android:layout_width="match_parent"
        android:paddingTop="120dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/digitsLayout">

        <include
            android:id="@+id/generatedDigitsLayout"
            layout="@layout/component_phone_number" />

        <Button
            android:id="@+id/generateNumberButton"
            style="@style/ConstrainHorizontalCenter"
            android:layout_marginTop="30dp"
            android:text="@string/generate_new_number"
            app:layout_constraintTop_toBottomOf="@id/generatedDigitsLayout"
            tools:ignore="MissingConstraints" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/restartButton"
        layout="@layout/component_restart_button" />

</androidx.constraintlayout.widget.ConstraintLayout>
