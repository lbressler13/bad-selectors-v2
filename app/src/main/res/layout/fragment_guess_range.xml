<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="@dimen/tab_activity_top_padding">

<!--    <include-->
<!--        android:id="@+id/settingsButton"-->
<!--        layout="@layout/component_settings_button" />-->

    <include
        android:id="@+id/dateNumbersLayout"
        layout="@layout/component_date_numbers" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainBody"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dateNumbersLayout"
        app:layout_constraintVertical_bias="0">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/dateRangeLayout"
            style="@style/FloatTopConstraintLayout"
            app:layout_constraintBottom_toTopOf="@id/buttonsLayout"
            tools:ignore="MissingConstraints">

            <TextView
                android:id="@+id/rangeQuestionText"
                style="@style/ConstrainHorizontalCenter"
                android:layout_marginTop="40dp"
                android:textSize="25sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                android:textColor="?colorOnBackground"
                tools:ignore="MissingConstraints" />

            <!-- Layout to display range values -->
            <LinearLayout
                style="@style/ConstrainHorizontalCenter"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rangeQuestionText"
                tools:ignore="MissingConstraints">

                <TextView
                    android:id="@+id/rangeStartText"
                    style="@style/GeneratedNumber" />

                <TextView
                    style="@style/GeneratedNumber"
                    android:paddingVertical="20dp"
                    android:textSize="40sp"
                    android:text="@string/to" />

                <TextView
                    android:id="@+id/rangeEndText"
                    style="@style/GeneratedNumber" />

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/singleValueLayout"
            style="@style/FloatTopConstraintLayout"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/buttonsLayout"
            tools:ignore="MissingConstraints">

            <TextView
                android:id="@+id/singleValueQuestionText"
                style="@style/ConstrainHorizontalCenter"
                android:layout_marginTop="40dp"
                android:textSize="25sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                android:textColor="?colorOnBackground"
                tools:ignore="MissingConstraints" />

            <!-- Text to display single number -->
            <TextView
                android:id="@+id/singleValueText"
                style="@style/GeneratedNumber"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/singleValueQuestionText" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Buttons at bottom of screen -->
        <LinearLayout
            android:id="@+id/buttonsLayout"
            style="@style/FullWidthLinearLayout"
            app:layout_constraintBottom_toBottomOf="parent"
            android:paddingBottom="20dp"
            tools:ignore="MissingConstraints">

            <Button
                android:id="@+id/yesButton"
                style="@style/SelectButton"
                android:text="@string/yes" />

            <Button
                android:id="@+id/noButton"
                style="@style/SelectButton"
                android:text="@string/no" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/restartButton"
        layout="@layout/component_restart_button" />

</androidx.constraintlayout.widget.ConstraintLayout>