<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="200dp">

    <include
        android:id="@+id/digitsLayout"
        layout="@layout/component_phone_number" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainBody"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/digitsLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/markCorrectText"
            android:layout_width="wrap_content"
            style="@style/ConstrainHorizontalCenter"
            android:text="@string/mark_correct"
            app:layout_constraintTop_toTopOf="parent"
            android:paddingTop="30dp"
            android:textSize="25sp"
            tools:ignore="MissingConstraints" />

        <Button
            android:id="@+id/generateNumberButton"
            style="@style/ConstrainHorizontalCenter"
            android:text="@string/generate_new_number"
            android:layout_marginTop="30dp"
            app:layout_constraintTop_toBottomOf="@id/markCorrectText"
            tools:ignore="MissingConstraints" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include layout="@layout/component_restart_button" android:id="@+id/restartButton" />

</androidx.constraintlayout.widget.ConstraintLayout>
